{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vite/client", "chrome"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "wxt.config.ts"],
  "exclude": ["node_modules", ".output", ".wxt"]
}
